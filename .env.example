# JWT Configuration
# IMPORTANT: Use a strong secret (minimum 32 characters) in production
JWT_SECRET=ReplaceThisWithAStrongSecretOfAtLeast32Chars!

# PostgreSQL Configuration
POSTGRES_DB=authdb
POSTGRES_USER=authuser
POSTGRES_PASSWORD=authpass

# Spring Profiles (default: prod when using docker-compose)
# SPRING_PROFILES_ACTIVE=prod
